# ==========================================================================
# Papo Dev Web — PRODUÇÃO. Copie para `.env` NO SERVIDOR, em
# /home/server/projects/icarojobs/papodevweb/.env  (NÃO versione).
# O CI preserva este arquivo (rsync --exclude .env).
# ==========================================================================

# ----- Geral -----
COMPOSE_PROJECT_NAME=papodevweb
ENVIRONMENT=production

# ----- Hosts (Traefik) -----
APP_HOST=papodevweb.com.br
API_HOST=api.papodevweb.com.br
MEDIA_HOST=media.papodevweb.com.br

# ----- MongoDB (gere senha forte: openssl rand -hex 24) -----
MONGO_INITDB_ROOT_USERNAME=papodevweb
MONGO_INITDB_ROOT_PASSWORD=__TROCAR__
MONGO_DB_NAME=papodevweb
MONGODB_URI=mongodb://papodevweb:__TROCAR__@mongodb:27017/?authSource=admin

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- RabbitMQ (gere senha forte) -----
RABBITMQ_DEFAULT_USER=papodevweb
RABBITMQ_DEFAULT_PASS=__TROCAR__
RABBITMQ_URL=amqp://papodevweb:__TROCAR__@rabbitmq:5672/

# ----- MinIO / S3 (gere senha forte) -----
MINIO_ROOT_USER=papodevweb
MINIO_ROOT_PASSWORD=__TROCAR__
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=media.papodevweb.com.br
MINIO_BUCKET=papodevweb-media
# Interno (minio:9000) é HTTP; público (atrás do Traefik) é HTTPS.
MINIO_USE_SSL=false
MINIO_PUBLIC_USE_SSL=true

# ----- Segurança / JWT (gere com: openssl rand -hex 32) -----
JWT_SECRET_KEY=__TROCAR__
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_RESET_TOKEN_EXPIRE_MINUTES=30

# ----- E-mail / SMTP de PRODUÇÃO (fornecido pelo cliente) -----
SMTP_HOST=__TROCAR__
SMTP_PORT=587
SMTP_FROM=no-reply@papodevweb.com.br
SMTP_FROM_NAME=Papo Dev Web
# (se o provedor exigir usuário/senha, o backend precisará suportá-los — ver nota no deploy)

# ----- CORS / Frontend (origem canônica) -----
FRONTEND_ORIGIN=https://papodevweb.com.br

# ----- Frontend (Vite, build-time) -----
VITE_API_URL=https://api.papodevweb.com.br
VITE_SOCKET_URL=https://api.papodevweb.com.br
