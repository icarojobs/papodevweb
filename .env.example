# ==========================================================================
# Papo Dev Web — variáveis de ambiente (copie para .env e ajuste os valores)
# ==========================================================================

# ----- Geral -----
COMPOSE_PROJECT_NAME=papodevweb
ENVIRONMENT=development

# ----- MongoDB -----
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root
MONGO_DB_NAME=papodevweb
MONGODB_URI=mongodb://root:root@mongodb:27017/?authSource=admin

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- RabbitMQ -----
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ----- MinIO (S3) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET=papodevweb-media
MINIO_USE_SSL=false

# ----- Segurança / JWT -----
# Gere com: openssl rand -hex 32
JWT_SECRET_KEY=troque-este-segredo-em-producao-com-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- E-mail / SMTP (Mailpit em desenvolvimento) -----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@papodevweb.local
SMTP_FROM_NAME=Papo Dev Web
# Console web do Mailpit: http://localhost:8075
JWT_RESET_TOKEN_EXPIRE_MINUTES=30

# ----- CORS / Frontend -----
FRONTEND_ORIGIN=http://localhost:5173

# ----- Frontend (Vite) -----
VITE_API_URL=http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000
